# Ihsane MVP Platform - Production Environment Configuration
# Domain: ihsan-dz.duckdns.org
#
# On first deploy, deploy.sh copies this file to .env
# and auto-generates POSTGRES_PASSWORD and SECRET_KEY.
#
# To customize, edit .env after first deploy:
#   nano .env
# ============================================

# Database Configuration
POSTGRES_USER=ihsane_user
POSTGRES_PASSWORD=will_be_auto_generated
POSTGRES_DB=ihsane

# Application Security
SECRET_KEY=will_be_auto_generated

# CORS Origins
CORS_ORIGINS=https://ihsan-dz.duckdns.org