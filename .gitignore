# ============================================================
# Smart-DA3M / Ihsane Platform — .gitignore
# ============================================================

# ------------------------------------------------------------
# Python / Backend
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
backend/venv/

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
coverage.xml
*.cover

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ruff cache
.ruff_cache/

# ------------------------------------------------------------
# Node.js / Frontend
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# pnpm store (local content-addressable store)
frontend/.pnpm-store/
.pnpm-store/

# Build outputs
frontend/dist/
frontend/dist-ssr/
*.local

# Vite
.vite/

# TypeScript
*.tsbuildinfo

# Testing
frontend/coverage/
frontend/playwright-report/
frontend/test-results/

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
*.db
*.sqlite3

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
# Don't ignore docker-compose or Dockerfiles — they're source
# (only ignore generated/sensitive runtime files)
.dockerignore

# ------------------------------------------------------------
# Environment / Secrets
# ------------------------------------------------------------
# Ignore all .env files EXCEPT examples/templates
.env.local
.env.*.local
.env.prod
.env.staging
.env.development
# Keep: .env.prod.example, .env.example (templates)

# ------------------------------------------------------------
# Editor & IDE
# ------------------------------------------------------------
# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# VS Code (ignore user-specific settings, keep shared config)
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# Jupyter
.ipynb_checkpoints

# Vim/Emacs swap
*.swp
*.swo
*~

# ------------------------------------------------------------
# OS generated
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Temp files
*.tmp
*.temp
*.bak

# ------------------------------------------------------------
# CI / Deployment
# ------------------------------------------------------------
# Keep: deploy.sh, Caddyfile, docker-compose*.yml
# Ignore runtime artefacts
*.pid
*.seed
*.pid.lock
