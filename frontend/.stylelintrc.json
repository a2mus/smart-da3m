{
  "extends": ["stylelint-config-standard"],
  "plugins": ["stylelint-plugin-logical-css"],
  "rules": {
    "logical-css/require-logical-properties": [true, {
      "ignore": ["top", "bottom", "margin-top", "margin-bottom", "padding-top", "padding-bottom", "border-top", "border-bottom", "max-height", "min-height", "height"]
    }],
    "logical-css/require-logical-keywords": true,
    "logical-css/require-logical-units": true,
    "declaration-property-value-disallowed-list": {
      "/.*/": [
        "#fff", "#FFF", "#ffffff", "#FFFFFF",
        "#000", "#000000", "white", "black",
        "rgb(0, 0, 0)",
        "rgb(255, 255, 255)"
      ]
    },
    "at-rule-no-unknown": [true, {
      "ignoreAtRules": ["tailwind", "apply", "variants", "responsive", "screen"]
    }],
    "font-family-name-quotes": null,
    "property-no-unknown": [true, {
      "ignoreProperties": ["font-display"]
    }],
    "declaration-empty-line-before": null,
    "alpha-value-notation": null,
    "shorthand-property-no-redundant-values": null,
    "color-function-alias-notation": null,
    "color-function-notation": null,
    "no-duplicate-selectors": null,
    "at-rule-empty-line-before": null
  }
}
